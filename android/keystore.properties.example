# Release signing — local only; never commit keystore.properties or *.jks.
#
# Maintainer: sign official APKs for GitHub Releases (see README § Android Release).
# Self-builders: use your own .jks to compile an APK you can update yourself.
#
#   cp keystore.properties.example keystore.properties
#   # edit storeFile (relative to android/) and passwords

storeFile=zerorelay-release.jks
storePassword=CHANGE_ME
keyAlias=zerorelay
keyPassword=CHANGE_ME
