<?xml version="1.0" encoding="utf-8"?>
<full-backup-content>
    <!-- 不备份 SharedPreferences 中的服务器、身份、加密与会话上下文 -->
    <exclude domain="sharedpref" path="zero_relay_prefs.xml" />
    <exclude domain="sharedpref" path="zero_relay_detached.xml" />
    <exclude domain="sharedpref" path="zero_relay_contacts.xml" />
    <exclude domain="sharedpref" path="zero_relay_identity.xml" />
    <exclude domain="sharedpref" path="zero_relay_ratchet.xml" />
    <exclude domain="sharedpref" path="zero_relay_tls_pins_enc.xml" />
    <exclude domain="sharedpref" path="zero_relay_tls_pins.xml" />
    <exclude domain="sharedpref" path="zero_relay_db_key.xml" />
    <!-- SQLCipher 加密消息库：防御性排除云备份 -->
    <exclude domain="database" path="zero_relay_messages" />
    <exclude domain="database" path="zero_relay_messages-shm" />
    <exclude domain="database" path="zero_relay_messages-wal" />
</full-backup-content>
